  "scripts": {
    "dev:all": "npm-run-all --parallel dev-client dev-server",
    "start": "pm2 start process.json",
    "start-x-core": "node ./dist/server/app.js",
    "build-client:test": "cross-env NODE_ENV=test webpack --config ./build/webpack.prod.other.js",
    "build-client:test-preview": "cross-env NODE_ENV=test webpack --config ./build/webpack.prod.preview.js",
    "build-client:gray": "cross-env NODE_ENV=gray webpack --config ./build/webpack.prod.other.js",
    "build-client:gray-preview": "cross-env NODE_ENV=gray webpack --config ./build/webpack.prod.preview.js",
    "build-client:prod": "cross-env NODE_ENV=prod webpack --config ./build/webpack.prod.other.js",
    "build-client:prod-preview": "cross-env NODE_ENV=prod webpack --config  ./build/webpack.prod.preview.js",
    "build-server:test": "cross-env NODE_ENV=test babel ./server/ --out-dir ./dist/server --config-file=./.babelrc",
    "build-server:gray": "cross-env NODE_ENV=gray babel ./server/ --out-dir ./dist/server --config-file=./.babelrc",
    "build-server:prod": "cross-env NODE_ENV=prod babel ./server/ --out-dir ./dist/server --config-file=./.babelrc",
    "build-client-babel:test": "cross-env NODE_ENV=test babel -D ./client/ --out-dir ./dist/client-babel --config-file=./.babelrc",
    "build-client-babel:gray": "cross-env NODE_ENV=gray babel -D ./client/ --out-dir ./dist/client-babel --config-file=./.babelrc",
    "build-client-babel:prod": "cross-env NODE_ENV=prod babel -D ./client/ --out-dir ./dist/client-babel --config-file=./.babelrc",
    "build:test": "npm run build-client:test && npm run build-client:test-preview &&  npm run build-server:test && npm run build-client-babel:test",
    "build:gray": "npm run build-client:gray && npm run build-client:gray-preview && npm run build-server:gray && npm run build-client-babel:gray",
    "build:prod": "npm run build-client:prod && npm run build-client:prod-preview && npm run build-server:prod && npm run build-client-babel:prod",
    "build": "npm run build-client:prod && npm run build-server:prod && npm run build-client-babel:prod",
    "debug": "cross-env NODE_ENV=dev nodemon --inspect-brk  server/app.js",
    "dev-client": "cross-env NODE_ENV=dev node --max_old_space_size=4096 build/webpack.server.js --measure && tsc",
    "dev-server": "cross-env NODE_ENV=dev nodemon server/app.js",
    "dev-prod-client": "cross-env NODE_ENV=prod node --max_old_space_size=4096 build/webpack.server.js --measure && tsc",
    "dev-prod-server": "cross-env NODE_ENV=prod nodemon server/app.js",
    "lint:eslint": "eslint --ext .js,.jsx --ignore-path .gitignore . --fix",
    "lint:prettier": "prettier --ignore-path .gitignore --write .",
    "lint": "npm run  lint:eslint && npm run lint:prettier"
  },
